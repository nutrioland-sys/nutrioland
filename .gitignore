# local env files
.env*.local

# live admin-editable data (orders, prices, content settings) — these change
# through the admin panel on the running server and must never be reverted
# or overwritten by a code deploy/rollback. Seeded once in the initial commit,
# then untracked (see deployment notes) so future edits stay local to the server.
/data/orders.json
/data/products.json
/data/categories.json
/data/hero.json
/data/analytics.json
/data/announcement.json
/data/customer-accounts.json
/data/auth-secret.json

# internal business docs — not meant for the public repo
/docs/

# vercel
.vercel

# machine-specific Claude Code settings, not project config
.claude/settings.local.json

# typescript
*.tsbuildinfo
next-env.d.ts
